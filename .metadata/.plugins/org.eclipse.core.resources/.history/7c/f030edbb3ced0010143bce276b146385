package loopingStmt.whileLoop;

public class NeonNumber {
	
	public static void main(String args[]) {
		
		int num=9;
		int square=num*num;
		int sum=0;
		int copy=num;
		
		while(square>0) {
			sum=sum+num%10;
			num=num/10;
		}
		
		if(sum==copy) {
			System.out.println("NEON NUMBER");
			else {
				
			}
		}
	}

}
