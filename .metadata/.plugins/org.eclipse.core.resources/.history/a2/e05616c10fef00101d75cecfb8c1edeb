package Assignments;

public class DifferenceMn {
	
	/*
	 * Explanation
		Sum of numbers divisible by 4 are 4 + 8 + 12 + 16 + 20 = 60
		Sum of numbers not divisible by 4 are 1 +2 + 3 + 5 + 6 + 7 + 9 + 10 + 11 + 13 + 14 + 15 + 17 + 18 + 19 = 150
		Difference: 150 – 60 = 90
	 */

	public static void main(String args[]) {
		
		int m=10;
		int n=2;
		int divSum=0,unDivSum=0;
		int diff;
		
		for(int i=1;i<=m;i++) {
			if(i%n==0) {
				divSum=divSum+i;
			}
			else {
				unDivSum=unDivSum+i;
			}
		}
		if(unDivSum>divSum) {
			diff=unDivSum-divSum;
		}
		else {
			diff=divSum-unDivSum;
		}
		System.out.println("Difference = "+diff);
	}
}
