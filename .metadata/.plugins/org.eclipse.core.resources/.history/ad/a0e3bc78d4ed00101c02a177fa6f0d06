package Assignments;

public class FibonacciSeries {
    public static void main(String[] args) {
        int n = 10; // number of terms

        int a = 0, b = 1;  // first two terms
        System.out.print("Fibonacci Series up to " + n + " terms: ");

        for (int i = 1; i <= n; i++) {
            System.out.print(a + " ");
            int next = a + b; // calculate next term
            a = b;
            b = next;
        }
    }
}